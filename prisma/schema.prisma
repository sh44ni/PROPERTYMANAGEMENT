generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTHENTICATION
// ============================================
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("user") // admin, user
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions      Session[]
  uploadedProjectDocuments ProjectDocument[] @relation("ProjectDocumentUploadedBy")
  replacedProjectDocuments ProjectDocument[] @relation("ProjectDocumentReplacedBy")
  passwordResetTokens PasswordResetToken[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())
}

// ============================================
// SETUP / ACTIVATION / PASSWORD RESET
// ============================================
model AppConfig {
  id               String   @id @default("app")
  mode             String   @default("notConfigured") // notConfigured, demo, live
  activatedAt      DateTime?
  activatedByEmail String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ActivationCode {
  id          String   @id @default(cuid())
  codeHash    String   @unique
  isUsed      Boolean  @default(false)
  usedAt      DateTime?
  usedByEmail String?
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================
// AREAS & CITIES
// ============================================
model City {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  areas     Area[]
}

model Area {
  id        String   @id @default(cuid())
  name      String
  cityId    String
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, cityId])
}

// ============================================
// PROJECTS
// ============================================
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  location    String?
  address     String?
  city        String?
  image       String?
  budget      Float    @default(0)
  spent       Float    @default(0)
  totalUnits  Int      @default(0)
  soldUnits   Int      @default(0)
  status      String   @default("planning") // planning, in_progress, completed
  progress    Int      @default(0) // 0-100
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propertyNumber  String?
  buildingName    String?
  propertyType    String?
  mobileNumber    String?
  districtName    String?
  floors          Int?
  facadeLength    Float?
  transactionType String?
  propertyArea    Float?

  ownerId         String?
  owner           Owner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  // Relations
  properties  Property[]
  updates     ProjectUpdate[]
  documents   ProjectDocument[]
}

model ProjectDocument {
  id                  String   @id @default(cuid())

  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  documentType         String

  originalFileName     String
  storedFileName       String
  storagePath          String

  mimeType             String
  fileSize             Int

  // Optional converted/derived preview (used for HEIC/HEIF and any future conversions)
  previewStoredFileName String?
  previewStoragePath    String?
  previewMimeType       String?
  previewFileSize       Int?

  notes               String?

  uploadedAt          DateTime @default(now())
  uploadedById        String?
  uploadedBy          User?    @relation("ProjectDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull, map: "ProjectDocument_uploadedById_fkey")

  // Replace/history support
  isActive            Boolean  @default(true)
  replacedAt          DateTime?
  replacedById        String?
  replacedBy          User?    @relation("ProjectDocumentReplacedBy", fields: [replacedById], references: [id], onDelete: SetNull, map: "ProjectDocument_replacedById_fkey")

  deletedAt           DateTime?

  @@index([projectId, documentType])
  @@index([projectId, isActive])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  details   String
  progress  Int
  updatedAt DateTime @default(now())
}

// ============================================
// PROPERTIES
// ============================================
model Property {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  unitNumber  String?  // رقم الشقة / الوحدة
  title       String
  type        String   // villa, apartment, land, building, commercial
  status      String   @default("available") // available, rented, sold
  area        String?
  location    String?
  price       Float    @default(0)
  bedrooms    Int?
  bathrooms   Int?
  description String?
  images      String[] // Array of image URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  maintenance      String?
  balconies        Int?
  floor            String?
  electricityMeter String?

  ownerId         String?
  owner           Owner?   @relation(fields: [ownerId], references: [id])

  // Relations
  rentals       Rental[]
  transactions  Transaction[]
}

// ============================================
// OWNERS
// ============================================
model Owner {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String
  nationality  String?
  address      String?
  idType1      String?  // passport, national_id, etc.
  idNumber1    String?
  idImage1     String?
  idType2      String?
  idNumber2    String?
  idImage2     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  properties   Property[]
  projects     Project[]
  transactions Transaction[]
}


// ============================================
// CUSTOMERS
// ============================================
model Customer {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String
  nationality  String?
  address      String?
  idType1      String?  // passport, national_id, etc.
  idNumber1    String?
  idImage1     String?
  idType2      String?
  idNumber2    String?
  idImage2     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  rentals         Rental[]
  transactions    Transaction[]
  rentalContracts RentalContract[]
  saleContracts   SaleContract[]   @relation("Buyer")
}

// ============================================
// RENTALS
// ============================================
model Rental {
  id             String    @id @default(cuid())
  propertyId     String
  property       Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime
  monthlyRent    Float
  depositAmount  Float     @default(0)
  paymentDay     Int       @default(1) // Day of month when rent is due
  status         String    @default("active") // active, expired, terminated
  paidUntil      DateTime?
  paymentStatus  String    @default("paid") // paid, pending, overdue
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  transactions Transaction[]
}

// ============================================
// TRANSACTIONS (Accounts)
// ============================================
model Transaction {
  id            String    @id @default(cuid())
  transactionNo String    @unique
  category      String    // income, expense
  type          String    // rent_payment, deposit, maintenance, utilities, etc.
  amount        Float
  paidBy        String    // Name of payer/payee
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  rentalId      String?
  rental        Rental?   @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  ownerId       String?
  owner         Owner?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  paymentMethod String    // cash, card, bank_transfer, cheque
  reference     String?
  description   String?
  
  // Owner Payment Specifics
  commissionRate   Float?
  commissionAmount Float?
  netAmount        Float?

  taxInvoice    TaxInvoice?
  
  receiptImage  String?
  status        String    @default("active") // active, cancelled
  cancelledAt   DateTime?
  cancelReason  String?
  date          DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// CONTRACTS
// ============================================
model RentalContract {
  id                String   @id @default(cuid())
  contractNumber    String   @unique
  status            String   @default("draft") // draft, signed, terminated
  
  // Landlord (First Party)
  landlordName      String
  landlordCR        String?
  landlordPOBox     String?
  landlordPostalCode String?
  landlordAddress   String?
  landlordPhone     String?
  landlordCivilId   String?
  
  // Tenant (Second Party)
  tenantId          String?
  tenant            Customer? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  tenantName        String
  tenantIdPassport  String
  tenantLabourCard  String?
  tenantPhone       String
  tenantEmail       String?
  tenantSponsor     String?
  tenantCR          String?
  tenantAddress     String?
  
  // Property Details
  propertyLandNumber     String?
  propertyArea           String?
  propertyBuiltUpArea    String?
  propertyDistrictNumber String?
  propertyStreetNumber   String?
  propertyLocation       String?
  propertyMapNumber      String?
  propertyBuildingName   String?
  propertyApartmentNumber String?
  propertyFloorNumber    String?
  
  // Contract Terms
  validFrom         DateTime
  validTo           DateTime
  agreementPeriod   String?
  agreementPeriodUnit String?  @default("months") // months, years
  monthlyRent       Float
  paymentFrequency  String   @default("monthly") // monthly, quarterly, yearly
  
  // Signatures
  landlordSignature String?
  landlordSignDate  DateTime?
  tenantSignature   String?
  tenantSignDate    DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SaleContract {
  id                   String   @id @default(cuid())
  contractNumber       String   @unique
  status               String   @default("draft") // draft, signed, completed
  
  // Seller (First Party)
  sellerNationalId     String?
  sellerName           String
  sellerCR             String?
  sellerNationality    String?
  sellerAddress        String?
  sellerPhone          String?
  
  // Buyer (Second Party)
  buyerId              String?
  buyer                Customer? @relation("Buyer", fields: [buyerId], references: [id], onDelete: SetNull)
  buyerNationalId      String?
  buyerName            String
  buyerCR              String?
  buyerNationality     String?
  buyerAddress         String?
  buyerPhone           String?
  
  // Property Details
  propertyWilaya       String
  propertyGovernorate  String?
  propertyPhase        String?
  propertyLandNumber   String?
  propertyArea         String?
  propertyBuiltUpArea  String?
  propertyDistrictNumber String?
  propertyStreetNumber String?
  propertyLocation     String?
  propertyMapNumber    String?
  
  // Payment Terms
  totalPrice           Float
  totalPriceWords      String?
  depositAmount        Float    @default(0)
  depositAmountWords   String?
  depositDate          DateTime?
  remainingAmount      Float    @default(0)
  remainingAmountWords String?
  remainingDueDate     DateTime?
  finalPaymentAmount   Float    @default(0)
  finalPaymentWords    String?
  
  // Construction Timeline
  constructionStartDate DateTime?
  constructionEndDate   DateTime?
  
  notes                String?
  sellerSignature      String?
  buyerSignature       String?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ============================================
// DOCUMENTS
// ============================================
model Document {
  id           String   @id @default(cuid())
  name         String
  originalName String
  type         String   // pdf, doc, image, etc.
  category     String   // legal, rental_agreement, invoice, etc.
  size         Int      // bytes
  mimeType     String
  filePath     String?  // Path to stored file
  fileUrl      String?  // URL if stored in cloud
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// TAX INVOICE
// ============================================
model TaxInvoice {
  id              String   @id @default(cuid())
  taxInvoiceNo    String   @unique
  date            DateTime @default(now())
  
  // Link to existing transaction (receipt/income)
  transactionId   String   @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  // Tax Details
  ownerTaxNumber  String?
  tenantTaxNumber String?
  paymentMethod   String?
  
  // Financials
  baseAmount      Float    // Typically the transaction amount
  discount        Float    @default(0)
  netBeforeTax    Float
  taxRate         Float    @default(0) // Percentage, e.g. 5
  vatAmount       Float
  netAfterTax     Float
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
